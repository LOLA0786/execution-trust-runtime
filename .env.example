# Execution Trust Runtime Environment Variables
# Copy to .env and fill in real values for production

# Redis (already used)
REDIS_URL=redis://localhost:6379/0

# Postgres (new for approval_requests table)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=trust_runtime
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/trust_runtime

# Secret for HMAC token signing (must be strong, 32+ chars)
SECRET_KEY=change-this-to-a-very-long-random-secret-key-for-hmac-approval-tokens-2026

# External services for Human-in-the-Loop notifications (Slack + SMTP email)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here
SLACK_SECURITY_CHANNEL=#security-alerts

# SMTP for EmailNotifier (stdlib smtplib - no SendGrid)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-or-token
ETR_FROM_EMAIL=no-reply@execution-trust.com

# Host for approval URLs (used in emails/Slack buttons)
ETR_HOST=localhost:8000
ETR_API_KEY=dev-etr-key-change-in-prod

# Vault / Runtime settings
VAULT_ENABLED=true
PROD_MODE=false
WORLD_STATE_INTEGRITY_ENABLED=true

# Celery / FastAPI
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Salesforce Sandbox (for Revenue Ops live connection - OAuth2 via simple-salesforce)
# Get from Setup > Apps > OAuth or User > Reset Security Token
SF_USERNAME=your-sandbox-username@company.com
SF_PASSWORD=your-sandbox-password
SF_SECURITY_TOKEN=your-security-token-here
SF_SANDBOX=true
# Optional for full OAuth2 client credentials flow (if username/password blocked):
# SF_CLIENT_ID=your-connected-app-client-id
# SF_CLIENT_SECRET=your-client-secret
# SF_INSTANCE_URL=https://your-instance.my.salesforce.com

# Slack for Chief of Staff Agent + Live Demo (scopes: channels:history, chat:write, im:write for DMs)
# Create Slack App, install to workspace, add bot to channels, invite to DMs.
# For live demo: set your Slack user ID or email for DM to your phone.
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SECURITY_CHANNEL=#security-alerts
SLACK_CHANNELS_TO_MONITOR=#general,#executive,#revenue,#executive-briefing
APPROVER_EMAIL=your-slack-handle-or-email@company.com  # DM target for approval (your phone)
# Create #executive-briefing channel and invite the bot
